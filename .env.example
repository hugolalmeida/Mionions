# ──────────────────────────────────────────────────────────────
# Configuração do Bot Mionions — Monitoramento de Criptomoedas
# ──────────────────────────────────────────────────────────────
# Copie este arquivo para .env e preencha os valores

# Token do seu bot no Discord Developer Portal
DISCORD_TOKEN=seu_token_aqui

# ID do canal onde os alertas serão enviados
# (Clique com botão direito no canal → Copiar ID — requer modo desenvolvedor)
CHANNEL_ID=123456789012345678

# ID do servidor Discord (para sincronização instantânea de slash commands)
# Clique com botão direito no servidor → Copiar ID
GUILD_ID=123456789012345678

# Símbolos a monitorar (pares USDT na Binance, separados por vírgula)
SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT,BNBUSDT,XRPUSDT,UNIUSDT,LDOUSDT,DOTUSDT

# Threshold de variação para disparar alerta
# 0.05 = 5% | 0.10 = 10%
ALERT_THRESHOLD=0.05

# Intervalo de verificação em segundos (padrão: 60s)
CHECK_INTERVAL=60

# Cooldown mínimo entre alertas do mesmo ativo em segundos (padrão: 5min)
ALERT_COOLDOWN=300
